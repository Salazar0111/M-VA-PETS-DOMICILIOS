# ─── Meta / WhatsApp Cloud API ───────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=          # ID del número en Meta Business
WHATSAPP_ACCESS_TOKEN=             # Token de acceso permanente (Meta)
WHATSAPP_VERIFY_TOKEN=             # Token secreto que defines tú para verificar el webhook

# ─── Meta / Instagram DM API ─────────────────────────────────────────────────
INSTAGRAM_PAGE_ACCESS_TOKEN=       # Token de la página de FB vinculada a IG
INSTAGRAM_VERIFY_TOKEN=            # Token secreto para verificar el webhook de IG

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # sk-ant-...

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
